//  GITHUB PUSH
// â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

/**
 * Pushes system-info.json to a GitHub repository in a dedicated
 * directory. Uses git CLI via child_process.
 *
 * Flow:
 *  1. Validate that the repo URL is configured.
 *  2. Clone the repo into a temp directory (shallow clone).
 *  3. Create the target directory inside the clone.
 *  4. Copy system-info.json into it.
 *  5. git add, commit, push.
 *  6. Clean up the temp directory.
 *
 * @param {string} repoUrl - The SSH or HTTPS repo URL.
 */
function pushToGitHub(repoUrl) {
  const jsonPath = path.join(BASE_DIR, OUTPUT_FILE);

  // Ensure the JSON file exists â€” generate it if not
  if (!fs.existsSync(jsonPath)) {
    console.log("  \x1b[33m! system-info.json not found. Generating it first...\x1b[0m\n");
    runSystemInfo();
  }

  // Check git is available
  if (!run("git --version")) {
    console.error("  \x1b[31mâœ– git is not installed or not on PATH.\x1b[0m");
    process.exit(1);
  }

  const timestamp = new Date().toISOString().replace(/[:.]/g, "-");
  const tempDir = path.join(BASE_DIR, `.tmp-git-push-${Date.now()}`);

  try {
    // Clone (shallow) â€” sanitize URL for display (strip token)
    const displayUrl = repoUrl.replace(/\/\/[^@]+@/, "//");
    console.log(`  \x1b[90mCloning ${displayUrl}...\x1b[0m`);
    const cloneResult = run(`git clone --depth 1 "${repoUrl}" "${tempDir}"`);
    if (cloneResult === null) {
      console.error("  \x1b[31mâœ– git clone failed. Check your repo URL and SSH keys.\x1b[0m");
      process.exit(1);
    }

    // Create target directory
    const targetDir = path.join(tempDir, GITHUB_DIR);
    if (!fs.existsSync(targetDir)) {
      fs.mkdirSync(targetDir, { recursive: true });
    }

    // Copy the JSON file (only 1 file â€” crud log is already embedded)
    const destFile = path.join(targetDir, path.basename(jsonPath));
    fs.copyFileSync(jsonPath, destFile);
    console.log(`  \x1b[90mCopied ${path.basename(jsonPath)} â†’ ${GITHUB_DIR}/${path.basename(jsonPath)}\x1b[0m`);

    // Git add, commit, push
    const gitOpts = { cwd: tempDir, encoding: "utf-8", timeout: 30000, stdio: ["pipe", "pipe", "pipe"] };
    execSync(`git add "${GITHUB_DIR}"`, gitOpts);

    // Check if there are changes to commit
    const status = execSync("git status --porcelain", gitOpts).toString().trim();
    if (!status) {
      console.log("  \x1b[33m! No changes to push (JSON is identical to what's already on GitHub).\x1b[0m");
    } else {
      const commitMsg = `SystemPulse report ${timestamp}`;
      execSync(`git commit -m "${commitMsg}"`, gitOpts);
      console.log(`  \x1b[90mCommitting: ${commitMsg}\x1b[0m`);

      execSync("git push", gitOpts);
      console.log(`\n  \x1b[1m\x1b[92mâœ” Pushed to GitHub:\x1b[0m ${displayUrl} â†’ ${GITHUB_DIR}/\n`);
    }
  } catch (err) {
    console.error(`  \x1b[31mâœ– GitHub push failed: ${err.message}\x1b[0m`);
    process.exit(1);
  } finally {
    // Clean up temp directory
    try {
      fs.rmSync(tempDir, { recursive: true, force: true });
    } catch { /* best effort cleanup */ }
  }
}

